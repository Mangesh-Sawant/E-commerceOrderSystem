<p class="font-body-md text-body-md text-on-surface-variant">Sign up to begin your wellness journey.</p>
</div>
<form class="space-y-6">
<div>
<label class="block font-label-sm text-label-sm text-on-surface mb-1" for="fullName">Full Name</label>
<input class="w-full px-4 py-3 bg-surface-container-lowest input-border rounded text-on-surface font-body-md focus:outline-none input-focus transition-colors" id="fullName" name="fullName" placeholder="John Doe" required="" type="text" />
</div>
<div>
<label class="block font-label-sm text-label-sm text-on-surface mb-1" for="email">Email Address</label>
<input class="w-full px-4 py-3 bg-surface-container-lowest input-border rounded text-on-surface font-body-md focus:outline-none input-focus transition-colors" id="email" name="email" placeholder="john@example.com" required="" type="email" />
</div>
<div>
<label class="block font-label-sm text-label-sm text-on-surface mb-1" for="password">Password</label>
<div class="relative">
<input class="w-full px-4 py-3 bg-surface-container-lowest input-border rounded text-on-surface font-body-md focus:outline-none input-focus transition-colors pr-10" id="password" name="password" placeholder="••••••••" required="" type="password" />
<button class="absolute right-3 top-1/2 -translate-y-1/2 text-on-surface-variant hover:text-primary transition-colors" type="button">
<span class="material-symbols-outlined" style="font-variation-settings: 'FILL' 0;">visibility_off</span>
</button>
</div>
</div>
<div>
<label class="block font-label-sm text-label-sm text-on-surface mb-1" for="confirmPassword">Confirm Password</label>
<div class="relative">
<input class="w-full px-4 py-3 bg-surface-container-lowest input-border rounded text-on-surface font-body-md focus:outline-none input-focus transition-colors pr-10" id="confirmPassword" name="confirmPassword" placeholder="••••••••" required="" type="password" />
<button class="absolute right-3 top-1/2 -translate-y-1/2 text-on-surface-variant hover:text-primary transition-colors" type="button">
<span class="material-symbols-outlined" style="font-variation-settings: 'FILL' 0;">visibility_off</span>
</button>
</div>
</div>
<div class="flex items-start gap-2">
<div class="flex items-center h-5">
<input class="w-4 h-4 border-outline-variant rounded bg-surface-container-lowest text-primary-container focus:ring-primary-container focus:ring-2" id="terms" required="" type="checkbox" />
</div>
<label class="font-body-md text-body-md text-on-surface-variant text-sm" for="terms">
