<script>
        document.addEventListener('DOMContentLoaded', () => {
            const markAllBtn = document.getElementById('markAllReadBtn');
            const cards = document.querySelectorAll('.notification-card');
            const globalNotificationDot = document.querySelector('nav button[aria-label="notifications"] span.absolute');

            markAllBtn.addEventListener('click', () => {
                cards.forEach(card => {
                    if(card.classList.contains('unread')) {
                        card.classList.remove('unread');
                        card.classList.add('read');
                        card.classList.remove('bg-surface-container-lowest', 'shadow-sm', 'hover:shadow-md');
                        card.classList.add('bg-surface-bright', 'opacity-80');
                        
                        // Icon color adjustments
                        const iconContainer = card.querySelector('div.w-12.h-12');
                        iconContainer.classList.remove('bg-surface-container', 'text-primary', 'text-[#D90429]');
                        iconContainer.classList.add('bg-surface-container-low', 'text-on-surface-variant');
                    }
                });
                
                if(globalNotificationDot) {
                    globalNotificationDot.style.display = 'none';
                }
            });

            cards.forEach(card => {
                card.addEventListener('click', function() {
                     if(this.classList.contains('unread')) {
                        this.classList.remove('unread');
                        this.classList.add('read');
                        this.classList.remove('bg-surface-container-lowest', 'shadow-sm', 'hover:shadow-md');
                        this.classList.add('bg-surface-bright', 'opacity-80');

                        const iconContainer = this.querySelector('div.w-12.h-12');
                        iconContainer.classList.remove('bg-surface-container', 'text-primary', 'text-[#D90429]');
                        iconContainer.classList.add('bg-surface-container-low', 'text-on-surface-variant');
                        
                        // Check if all read to hide global dot
                        const unreadRemaining = document.querySelectorAll('.notification-card.unread').length;
                        if(unreadRemaining === 0 && globalNotificationDot) {
                             globalNotificationDot.style.display = 'none';
                        }
                     }
                });
            });
        });
    </script>
