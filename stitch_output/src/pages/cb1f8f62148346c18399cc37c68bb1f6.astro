<!-- Inline script for basic toggle logic mirroring UI state -->
<script>
        document.querySelectorAll('input[type="checkbox"]').forEach(toggle => {
            toggle.addEventListener('change', function() {
                const label = this.nextElementSibling;
                if (this.checked) {
                    this.style.right = '0';
                    this.style.left = 'auto';
                    this.style.borderColor = '#012d1d'; // Primary color
                    label.style.backgroundColor = '#012d1d';
                } else {
                    this.style.left = '0';
                    this.style.right = 'auto';
                    this.style.borderColor = '#e1e3e4'; // Surface variant
                    label.style.backgroundColor = '#e1e3e4';
                }
            });
            // Init state visually for custom toggles without pure CSS sibling selectors if needed, 
            // though CSS handles most of it above.
        });
    </script>
</body></html>