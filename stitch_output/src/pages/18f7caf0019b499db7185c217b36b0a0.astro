<div class="absolute inset-0 z-0">
<img alt="Current hero banner showing natural ayurvedic products in a serene setting" class="w-full h-full object-cover opacity-60 group-hover:opacity-40 transition-opacity" data-alt="A wide cinematic shot of a beautifully arranged modern apothecary setting. Dark green amber glass bottles of natural oils and serums sit on a pristine white marble slab. Soft, diffused morning sunlight streams across the scene, casting elegant, elongated shadows. Delicate dried botanical sprigs, like eucalyptus and lavender, are scattered sparsely to emphasize purity and natural ingredients. The aesthetic is clean, minimalist, high-end corporate natural wellness." src="/assets/db618f5f0e2cec1e3ed6c0d05dd7960a.png" />
</div>
<!-- Upload Overlay -->
<div class="relative z-10 flex flex-col items-center text-center p-4 bg-surface/80 backdrop-blur-sm rounded-lg shadow-sm border border-outline-variant">
<span class="material-symbols-outlined text-primary-container text-3xl mb-2" data-icon="cloud_upload">cloud_upload</span>
<p class="text-label-md font-label-md text-on-surface">Drag &amp; drop new image here</p>
<p class="text-label-sm font-label-sm text-on-surface-variant mt-1">or click to browse (Recommended: 1920x800px)</p>
</div>
</div>
</div>
<!-- Banner Content Fields -->
<div class="grid grid-cols-1 md:grid-cols-2 gap-6">
<div class="space-y-5">
<div>
<label class="block text-label-sm font-label-sm text-on-surface mb-2" for="banner_headline">Headline Text</label>
<input class="w-full bg-surface p-3 rounded border border-outline-variant text-body-md font-body-md text-on-surface focus:ring-1 focus:ring-primary focus:border-primary transition-colors" id="banner_headline" type="text" value="Pure Nature, Clinical Precision" />
</div>
<div>
<label class="block text-label-sm font-label-sm text-on-surface mb-2" for="banner_subhead">Subheadline Text</label>
<textarea class="w-full bg-surface p-3 rounded border border-outline-variant text-body-md font-body-md text-on-surface focus:ring-1 focus:ring-primary focus:border-primary transition-colors" id="banner_subhead" rows="2">Discover our new line of scientifically backed herbal remedies.</textarea>
</div>
</div>
<div class="space-y-5">
<div>
