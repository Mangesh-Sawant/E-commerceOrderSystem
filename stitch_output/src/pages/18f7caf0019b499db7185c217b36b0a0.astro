</div>
<span class="px-3 py-1 bg-secondary-container text-on-secondary-container rounded-full text-label-sm font-label-sm">Active Section</span>
</div>
<!-- Image Upload Area -->
<div class="mb-8">
<label class="block text-label-sm font-label-sm text-on-surface mb-2">Banner Image (Desktop)</label>
<div class="relative w-full h-64 border-2 border-dashed border-outline-variant rounded-lg bg-surface flex flex-col items-center justify-center overflow-hidden group hover:border-primary-fixed-dim transition-colors cursor-pointer">
