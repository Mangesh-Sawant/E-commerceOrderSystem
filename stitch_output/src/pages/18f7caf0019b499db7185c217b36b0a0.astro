<input class="w-full bg-surface p-3 rounded border border-outline-variant text-body-md font-body-md text-on-surface focus:ring-1 focus:ring-primary focus:border-primary transition-colors" id="cta_text" type="text" value="Shop the Collection" />
</div>
<div>
<label class="block text-label-sm font-label-sm text-on-surface mb-2" for="cta_link">Button Link / URL</label>
<input class="w-full bg-surface p-3 rounded border border-outline-variant text-body-md font-body-md text-on-surface focus:ring-1 focus:ring-primary focus:border-primary transition-colors" id="cta_link" type="url" value="/collections/new-arrivals" />
</div>
</div>
</div>
<!-- CTA Preview -->
<div class="mt-8 pt-6 border-t border-outline-variant">
<p class="text-label-sm font-label-sm text-on-surface-variant mb-4 uppercase tracking-wider">Button Preview</p>
<div class="inline-block px-8 py-3 bg-[#D90429] text-white font-label-md text-label-md uppercase font-bold rounded shadow-sm">
                                Shop the Collection
                            </div>
</div>
</section>
</div>
</div>
</div>
