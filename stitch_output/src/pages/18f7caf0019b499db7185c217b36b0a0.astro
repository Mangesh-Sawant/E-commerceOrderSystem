<main class="ml-64 flex-1 overflow-y-auto bg-surface p-8 md:p-12">
<div class="max-w-container-max mx-auto space-y-12">
<!-- Page Header -->
<header class="flex justify-between items-end border-b border-outline-variant pb-6">
<div>
<h2 class="text-headline-lg font-headline-lg text-primary mb-2">Marketing Settings</h2>
<p class="text-body-md font-body-md text-on-surface-variant">Manage storefront promotions and homepage visibility.</p>
</div>
<div class="flex gap-4">
<button class="px-6 py-2 border border-outline text-primary font-label-md text-label-md rounded hover:bg-surface-container transition-colors">Cancel</button>
<button class="px-6 py-2 bg-primary-container text-on-primary font-label-md text-label-md rounded hover:bg-primary transition-colors shadow-sm soft-lift">Save Changes</button>
</div>
</header>
<!-- Settings Grid Layout -->
<div class="grid grid-cols-1 lg:grid-cols-3 gap-gutter">
<!-- Left Column: Global Announcements -->
<div class="lg:col-span-1 space-y-8">
