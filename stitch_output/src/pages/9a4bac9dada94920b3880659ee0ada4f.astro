<body class="bg-background text-on-surface font-body-md h-full flex flex-col antialiased selection:bg-primary selection:text-on-primary">
<!-- Suppressed TopNavBar due to transactional intent (Forgot Password) -->
<main class="flex-grow flex items-center justify-center p-margin-mobile md:p-margin-desktop relative overflow-hidden">
<!-- Decorative background element -->
<div class="absolute inset-0 z-0 pointer-events-none opacity-40">
<img alt="" class="w-full h-full object-cover blur-sm mix-blend-multiply opacity-20 object-left-top" data-alt="A macro, out-of-focus background shot of delicate, pale green sage leaves bathed in soft, diffused natural morning light. The image features shallow depth of field, creating a smooth, serene bokeh effect that feels botanical and calming. The palette is dominated by soft mint greens, creamy off-whites, and gentle, earthy tones, perfectly aligning with a modern apothecary and natural medicine aesthetic. The lighting is bright and ethereal, suggesting purity and natural wellness." src="/assets/05279217af2f949b02b0b442efb9bfb6.png" />
</div>
<div class="relative z-10 w-full max-w-md bg-surface-container-lowest rounded-xl shadow-[0px_10px_20px_rgba(27,67,50,0.08)] border border-outline-variant p-8 md:p-10 flex flex-col gap-6">
<div class="text-center mb-2">
<h1 class="text-headline-md font-headline-md text-primary mb-2">Forgot Password</h1>
<p class="text-body-md font-body-md text-on-surface-variant">Enter your email address and we'll send you a link to reset your password.</p>
</div>
<!-- Initial Form State -->
<form class="flex flex-col gap-6" id="resetForm" onsubmit="handleResetSubmit(event)">
<div class="flex flex-col gap-2">
<label class="text-label-md font-label-md text-on-surface" for="email">Email Address</label>
<div class="relative group">
<span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-outline group-focus-within:text-primary transition-colors">mail</span>
<input class="w-full pl-10 pr-4 py-3 bg-surface-bright border border-outline-variant rounded-lg text-body-md text-on-surface focus:outline-none focus:border-primary focus:ring-1 focus:ring-primary transition-all placeholder:text-outline" id="email" name="email" placeholder="your@email.com" required="" type="email" />
</div>
</div>
<button class="w-full py-3 px-6 bg-tertiary-container text-on-tertiary text-label-md font-label-md uppercase tracking-wider rounded-lg hover:shadow-[0px_10px_20px_rgba(27,67,50,0.08)] hover:bg-[#D90429] transition-all duration-300 flex items-center justify-center gap-2 group" type="submit">
<span>Send Reset Link</span>
<span class="material-symbols-outlined text-[18px] group-hover:translate-x-1 transition-transform">arrow_forward</span>
</button>
<div class="text-center mt-2">
<a class="text-label-md font-label-md text-secondary hover:text-primary transition-colors flex items-center justify-center gap-1" href="#">
<span class="material-symbols-outlined text-[16px]">arrow_back</span>
                        Back to Login
                    </a>
</div>
</form>
<!-- Success State (Hidden by default) -->
<div class="hidden flex-col items-center text-center gap-6 py-4 animate-[fadeIn_0.5s_ease-out]" id="successState">
<div class="w-16 h-16 rounded-full bg-secondary-container flex items-center justify-center mb-2">
<span class="material-symbols-outlined text-[32px] text-secondary">check_circle</span>
</div>
<div>
<h2 class="text-headline-md font-headline-md text-primary mb-2">Link Sent</h2>
<p class="text-body-md font-body-md text-on-surface-variant">We've sent a password reset link to <br /><strong class="text-on-surface font-semibold" id="submittedEmail" /></p>
</div>
<div class="w-full p-4 bg-surface-container-low rounded-lg border border-outline-variant mt-2 text-left">
<p class="text-label-sm font-label-sm text-on-surface-variant mb-1 flex items-center gap-1"><span class="material-symbols-outlined text-[14px]">info</span> Didn't receive it?</p>
<p class="text-body-md font-body-md text-on-surface-variant text-sm">Check your spam folder or <button class="text-secondary font-semibold hover:underline" onclick="resetFormState()">try another email address</button>.</p>
</div>
<a class="mt-4 text-label-md font-label-md text-secondary hover:text-primary transition-colors flex items-center justify-center gap-1" href="#">
<span class="material-symbols-outlined text-[16px]">arrow_back</span>
                    Return to Login
                </a>
</div>
</div>
</main>
<!-- Suppressed Footer due to transactional intent (Forgot Password) -->
<script>
        function handleResetSubmit(event) {
            event.preventDefault();
            const emailInput = document.getElementById('email').value;
            const form = document.getElementById('resetForm');
            const successState = document.getElementById('successState');
            const submittedEmailSpan = document.getElementById('submittedEmail');
            
            // Basic validation
            if(emailInput) {
                // Simulate API call and transition
                const submitBtn = form.querySelector('button[type="submit"]');
                const originalBtnText = submitBtn.innerHTML;
                
                submitBtn.innerHTML = '<span class="material-symbols-outlined animate-spin">progress_activity</span> <span>Sending...</span>';
                submitBtn.disabled = true;
                submitBtn.classList.add('opacity-80');

                setTimeout(() => {
                    submittedEmailSpan.textContent = emailInput;
                    form.classList.add('hidden');
                    successState.classList.remove('hidden');
                    successState.classList.add('flex');
                    
                    // Reset button state for if they come back
                    submitBtn.innerHTML = originalBtnText;
                    submitBtn.disabled = false;
                    submitBtn.classList.remove('opacity-80');
                    form.reset();
                }, 800);
            }
        }

        function resetFormState() {
            document.getElementById('successState').classList.add('hidden');
            document.getElementById('successState').classList.remove('flex');
            document.getElementById('resetForm').classList.remove('hidden');
            document.getElementById('resetForm').classList.add('flex');
            document.getElementById('email').focus();
        }
    </script>
<style>
        @keyframes fadeIn {
            from { opacity: 0; transform: translateY(10px); }
            to { opacity: 1; transform: translateY(0); }
        }
    </style>
</body></html>